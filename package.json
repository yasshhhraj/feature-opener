{
  "name": "feature-opener",
  "displayName": "feature-opener",
  "description": "open all files related to a feature in parallel in one click",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "feature-opener.openFeatureFiles",
        "title": "Open Feature Files"
      },
      {
        "command": "feature-opener.openImportedFiles",
        "title": "Open Imported Files"
      },
      {
        "command": "feature-opener.closeRelatedFiles",
        "title": "Close Related Files"
      },
      {
        "command": "feature-opener.copyFeatureChain",
        "title": "Copy Feature Chain as New Feature"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack",
    "watch": "webpack --watch",
    "package": "webpack --mode production --devtool hidden-source-map",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.120.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "ts-loader": "^9.5.4",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
